rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authenticated() {
      return request.auth != null;
    }

    match /config/allowedUsers {
      allow read: if authenticated();
      allow write: if false;
    }
    match /config/allowedUsers/{document=**} {
      allow read: if authenticated();
      allow write: if false;
    }
    match /plants/{document} {
      allow read, write: if authenticated();
    }
    match /slots/{slotId} {
      allow read: if authenticated();
      allow create: if authenticated() && request.resource.data.slotId == slotId;
      allow update: if authenticated()
        && resource.data.slotId == slotId
        && request.resource.data.slotId == slotId;
      allow delete: if authenticated();
    }
    match /workLogs/{document} {
      allow read, write: if authenticated();
    }
  }
}
